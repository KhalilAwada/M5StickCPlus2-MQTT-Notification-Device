# Copy this file to .env and fill in your real values.
# load_env.py reads .env at build time and injects values as -D macros.
# Never commit your real .env.

# --- Wi-Fi ---
WIFI_SSID=
WIFI_PASS=

# --- MQTT broker ---
MQTT_HOST=
MQTT_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC=m5stack/stickcp2
MQTT_CLIENT_ID=m5stack-stickc

# --- MQTT options ---
MQTT_CLEAN_SESSION=false
MQTT_QOS=1
MQTT_RETAIN=false

# --- TLS (set MQTT_TLS=1 to enable; typically pair with MQTT_PORT=8883) ---
MQTT_TLS=0
MQTT_TLS_INSECURE=0
